# yabai window management
# modifiers: command and option

# focus windows (alt + hjkl)
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# focus spaces
cmd - left : yabai -m space --focus prev
cmd - right : yabai -m space --focus next
alt - s : yabai -m space --focus prev
alt - g : yabai -m space --focus next

# focus spaces directly
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5
cmd - 6 : yabai -m space --focus 6
cmd - 7 : yabai -m space --focus 7
cmd - 8 : yabai -m space --focus 8
cmd - 9 : yabai -m space --focus 9

# move focused window between spaces and follow it
cmd - 0x21 : yabai -m window --space prev && yabai -m space --focus prev
cmd - 0x1E : yabai -m window --space next && yabai -m space --focus next

# move focused window directly to a space
cmd + shift - 1 : yabai -m window --space 1
cmd + shift - 2 : yabai -m window --space 2
cmd + shift - 3 : yabai -m window --space 3
cmd + shift - 4 : yabai -m window --space 4
cmd + shift - 5 : yabai -m window --space 5
cmd + shift - 6 : yabai -m window --space 6
cmd + shift - 7 : yabai -m window --space 7
cmd + shift - 8 : yabai -m window --space 8
cmd + shift - 9 : yabai -m window --space 9

# focus displays
alt - u : yabai -m display --focus prev
alt - i : yabai -m display --focus next

# swap windows
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

# move window to space and follow focus
shift + alt - s : yabai -m window --space prev; yabai -m space --focus prev
shift + alt - g : yabai -m window --space next; yabai -m space --focus next

# move window to display
shift + alt - u : yabai -m window --display prev
shift + alt - i : yabai -m window --display next

# layouts
alt - t : yabai -m space --layout bsp
alt - y : yabai -m space --layout stack
alt - z : yabai -m space --layout float

# toggle window float
alt - f : yabai -m window --toggle float

# toggle window zoom
alt - d : yabai -m window --toggle zoom-parent
alt - w : yabai -m window --toggle zoom-fullscreen

# toggle window sticky
alt - e : yabai -m window --toggle sticky

# rotate layout
alt - r : yabai -m space --rotate 90

# mirror layout
alt + shift - x : yabai -m space --mirror x-axis
alt + shift - y : yabai -m space --mirror y-axis

# balance windows
alt - b : yabai -m space --balance

# close window
alt - q : yabai -m window --close

# kill yabai/skhd
ctrl + alt - q : yabai -m window --close

# screenshot: click+drag freeform, copies to clipboard
cmd + shift - s : screencapture -i -c
