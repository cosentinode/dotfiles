{
  "$schema" : "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion" : 1,
  "app" : {
    "globalFontMagnification" : 150
  },
  "shortcuts" : {
    "bindings" : {
      "newTab" : null,
"newSurface" : "cmd+shift+t",
      "closeTab" : "cmd+shift+w",
      "nextSidebarTab" : "cmd+shift+down",
      "prevSidebarTab" : "cmd+shift+up",
      "nextSurface" : "cmd+shift+right",
      "prevSurface" : "cmd+shift+left",
      "splitRight" : "cmd+shift+return",
      "toggleSplitZoom" : null,
      "toggleFileExplorer" : "cmd+shift+b",
      "triggerFlash" : null
    }
  }
}
