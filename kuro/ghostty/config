# Font
font-family = JetBrainsMono Nerd Font
font-size = 22
adjust-cell-height = 15%

# Colors — OneDark Pro
background = 121212
background-opacity = 0.9

# Padding
window-padding-x = 10
window-padding-y = 10,2
window-padding-balance = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Cursor trail shaders (neovide-style GPU trails)
custom-shader = shaders/cursor_smear_fade.glsl

# Scrollback
scrollback-limit = 10000

# Splits
split-divider-color = #282C34

# macOS
macos-option-as-alt = left
macos-titlebar-style = hidden

# Keybindings
keybind = super+shift+h=goto_split:left
keybind = super+shift+l=goto_split:right
keybind = super+shift+arrow_left=text:\x1b[1;3D
keybind = super+shift+arrow_right=text:\x1b[1;3C
keybind = super+shift+t=text:\x00c
keybind = super+shift+backspace=text:\x00x
keybind = super+shift+enter=text:\x00|
